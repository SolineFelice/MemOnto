###  https://w3id.org/MemOnto#Anoetic_Consciousness
:Anoetic_Consciousness rdf:type owl:Class ;
                       rdfs:subClassOf :Consciousness ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty :isAssociatedWith ;
                                         owl:someValuesFrom :Procedural_Memory
                                       ] ;
                       terms:bibliographicCitation "Tulving, E. (1985). Memory and consciousness. Canadian Psychology / Psychologie canadienne, 26(1), 1–12. https://doi.org/10.1037/h0080017" ;
                       rdfs:comment "\"Anoetic consciousness is temporally and spatially bound to the current situation. Organisms possessing only anoetic consciousness are conscious in the sense that they are capable of perceptually registering, internally representing, and behaviourally responding to aspects of the present environment, both external and internal. Anoetic consciousness does not include any reference to non-present extraorganismic stimuli and states of the world.\" (Tulving, E. (1985))" ;
                       rdfs:label "Anoetic Consciousness"@en ;
                       skos:definition "\"According to Tulving, procedural memory is said to be anoetic as it is expressed directly in behavior and action, i.e. without consciousness.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                       skos:prefLabel "Anoetic Consciousness"@en .


###  https://w3id.org/MemOnto#Author
:Author rdf:type owl:Class .


###  https://w3id.org/MemOnto#Automation
:Automation rdf:type owl:Class ;
            rdfs:subClassOf :Memory_Process ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :isAssociatedWith ;
                              owl:someValuesFrom :Procedural_Memory
                            ] ;
            terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
            rdfs:label "Automation"@en ;
            skos:prefLabel "Automation"@en .


###  https://w3id.org/MemOnto#Autonoetic_Consciousness
:Autonoetic_Consciousness rdf:type owl:Class ;
                          rdfs:subClassOf :Consciousness ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty :isAssociatedWith ;
                                            owl:someValuesFrom :Episodic_Memory
                                          ] ;
                          terms:bibliographicCitation "Tulving, E. (1985). Memory and consciousness. Canadian Psychology / Psychologie canadienne, 26(1), 1–12. https://doi.org/10.1037/h0080017" ;
                          terms:bibliographicCitation "Tulving E. (2002). Episodic memory: from mind to brain. Annual review of psychology, 53, 1–25. https://doi.org/10.1146/annurev.psych.53.100901.135114" ;
                          rdfs:label "Autonoetic Consciousness"@en ;
                          skos:definition "\"Autonoetic (self-knowing) consciousness is the name given to the kind of consciousness that mediates an individual's awareness of his or her existence and identity in subjective time extending from the personal past through the present to the personal future.\" (Tulving, 1985, p. 1).\", Cognitive psychology of human memory (CogMemo thesaurus) " ;
                          skos:prefLabel "Autonoetic Consciousness"@en ;
                          skos:altLabel "Autonoetic_Awareness"@en .


###  https://w3id.org/MemOnto#Cognitive_Memory_System
:Cognitive_Memory_System rdf:type owl:Class .


###  https://w3id.org/MemOnto#Cognitive_Procedural_Learning
:Cognitive_Procedural_Learning rdf:type owl:Class ;
                               rdfs:subClassOf :Learning ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty :isPartOf ;
                                                 owl:someValuesFrom :Procedural_Memory
                                               ] ;
                               rdfs:label "Cognitive Procedural Learning"@en ;
                                          # "Mémoire Procédurale Cognitive"@fr ;
                               skos:definition "\"Improvement of the ease with which a task is performed over trials.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                               skos:prefLabel "Cognitive Procedural Learning"@en .
 

###  https://w3id.org/MemOnto#Consciousness
:Consciousness rdf:type owl:Class ;
               rdfs:label "Consciousness"@en ;
               skos:prefLabel "Consciousness"@en ;
               skos:definition "\"An organism’s awareness of something either internal or external to itself.\", APA Dictionary of Psychology" .


###  https://w3id.org/MemOnto#Consolidation
:Consolidation rdf:type owl:Class ;
               rdfs:subClassOf :Memory_Process ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :isAssociatedWith ;
                                 owl:someValuesFrom :Cognitive_Memory_System
                               ] ;
               terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
               rdfs:comment "\"A slow process whereby a still labile memory trace is converted into a more permanent or enhanced form, notably by establishing connections between the medial temporal lobes and neocortical areas.\" (Eustache, F., Desgranges, B. (2008))" ;
               rdfs:label "Consolidation"@en ;
               skos:definition "\"Time-dependent processes for strengthening, stabilizing, transferring and reorganizing memory traces.\", Cognitive psychology of human memory (CogMemo thesaurus) " ;
               skos:prefLabel "Consolidation"@en .


###  https://w3id.org/MemOnto#Declarative_Memory
:Declarative_Memory rdf:type owl:Class .


###  https://w3id.org/MemOnto#Episodic_Buffer
:Episodic_Buffer rdf:type owl:Class ;
                 rdfs:label "Episodic Buffer"@en .


###  https://w3id.org/MemOnto#Episodic_Memory
:Episodic_Memory rdf:type owl:Class ;
                 rdfs:subClassOf [ rdf:type owl:Restriction ;
                                   owl:onProperty :isIntegratedIn ;
                                   owl:someValuesFrom :MNESIS_Model
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :isPartOf ;
                                   owl:someValuesFrom :Declarative_Memory
                                 ] ;
                 terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                 rdfs:comment "\"Memory of personally experienced events, situated in the temporal-spatial context of their acquisition.\" (Eustache, F., Desgranges, B. (2008))" .


###  https://w3id.org/MemOnto#Learning
:Learning rdf:type owl:Class ;
          rdfs:subClassOf :Memory_Process ;
          skos:prefLabel "Learning"@en ;
          rdfs:label "Learning"@en .


###  https://w3id.org/MemOnto#MNESIS_Model
:MNESIS_Model rdf:type owl:Class ;
              terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
              terms:created "2003-01-01T01:01:01"^^xsd:dateTime ;
              rdfs:label "MNESIS Model"@en ;
              skos:altLabel "Memory NEoStructural Inter-Systemic Model"@en ;
              skos:prefLabel "MNESIS Model"@en ;
              rdfs:subClassOf :Memory_Model ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :defines ;
                                owl:someValuesFrom :Automation
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :defines ;
                                owl:someValuesFrom :Perceptual_Memory
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :defines ;
                                owl:someValuesFrom :Semanticization
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :SPI_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isRevisedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Long-Term_Memory 
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :SPI_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isRevisedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :PRS_Memory
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :SPI_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isRevisedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Primary_Memory
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :SPI_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isRevisedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Procedural_Memory
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :SPI_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isIntegratedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Semantic_Memory
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :SPI_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isIntegratedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Episodic_Memory
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :Multicomponent_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isIntegratedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Phonological_Loop
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :Multicomponent_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isIntegratedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Episodic_Buffer
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isComingFrom ;
                                                      owl:someValuesFrom :Multicomponent_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :isIntegratedIn ;
                                                      owl:someValuesFrom :MNESIS_Model
                                                    ]
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty :memoryComponent ;
                                                      owl:someValuesFrom :Visuo-Spatial_Sketchpad
                                                    ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                        owl:onProperty :fromConcept ;
                                                        owl:someValuesFrom :Phonological_Loop
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :fromModel ;
                                                        owl:someValuesFrom :Multicomponent_Model
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :integratedInModel ;
                                                        owl:someValuesFrom :MNESIS_Model
                                                      ]
                                                    ) ;
                                rdf:type owl:Class
                              ],
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                        owl:onProperty :fromConcept ;
                                                        owl:someValuesFrom :Episodic_Buffer
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :fromModel ;
                                                        owl:someValuesFrom :Multicomponent_Model
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :integratedInModel ;
                                                        owl:someValuesFrom :MNESIS_Model
                                                      ]
                                                    ) ;
                                rdf:type owl:Class
                              ],
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                        owl:onProperty :fromConcept ;
                                                        owl:someValuesFrom :Visuo-Spatial_Sketchpad
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :fromModel ;
                                                        owl:someValuesFrom :Multicomponent_Model
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :integratedInModel ;
                                                        owl:someValuesFrom :MNESIS_Model
                                                      ]
                                                    ) ;
                                rdf:type owl:Class
                              ];
              # :holdsTrue [ :isComingFrom :SPI_Model ;
              #              :isRevisedIn :MNESIS_Model ;
              #              :memorySystem :Long-Term_Memory 
              #            ] ,
              #            [ :isComingFrom :SPI_Model ;
