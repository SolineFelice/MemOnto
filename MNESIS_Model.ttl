###  https://w3id.org/MemOnto#Memory_Model
:Memory_Model rdf:type owl:Class .


###  https://w3id.org/MemOnto#Memory_Process
:Memory_Process rdf:type owl:Class .


###  https://w3id.org/MemOnto#Mental_Time_Travel
:Mental_Time_Travel rdf:type owl:Class ;
                    rdfs:subClassOf :Memory_Process ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :isAssociatedWith ;
                                      owl:someValuesFrom :Autonoetic_Consciousness
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :isAssociatedWith ;
                                      owl:someValuesFrom :Episodic_Memory
                                    ] ;
                    terms:bibliographicCitation "Tulving, E. (2002). EPISODIC MEMORY: From Mind to Brain. Annual Review of Psychology, 53(1), 1. https://doi-org.gorgone.univ-toulouse.fr/10.1146/annurev.psych.53.100901.135114" ;
                    rdfs:comment "\"From the present to the past, thus allowing one to re-experience, through autonoetic awareness, one’s own previous experiences.\" (Tulving, E. (2002))" ;
                    rdfs:label "Mental Time Travel"@en ;
                    skos:definition "\"\"[T]he faculty that allows humans to mentally project themselves backwards in time to re-live, or forwards to pre-live, events.\"(Suddendorf et Corballis, 2007, p. 299).\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                    skos:prefLabel "Mental Time Travel"@en .


###  https://w3id.org/MemOnto#Noetic_Consciousness
:Noetic_Consciousness rdf:type owl:Class ;
                      rdfs:subClassOf :Consciousness ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :isAssociatedWith ;
                                        owl:someValuesFrom :Semantic_Memory
                                      ] ;
                      rdfs:label "Noetic Consciousness"@en ;
                      skos:definition "\"According to Tulving (1985), awareness of knowledge about the world (knowing), based on a sense of familiarity and associated with semantic memory.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                      skos:prefLabel "Noetic Consciousness"@en .


###  https://w3id.org/MemOnto#Perceptual-Motor_Procedural_Learning
:Perceptual-Motor_Procedural_Learning rdf:type owl:Class ;
                                      rdfs:subClassOf :Learning ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :isPartOf ;
                                                        owl:someValuesFrom :Procedural_Memory
                                                      ] ;
                                      rdfs:label "Perceptual-Motor Procedural Learning"@en ;
                                      # rdfs:label "Mémoire Procédurale Perceptive-Motrice"@fr ,
                                      skos:prefLabel "Perceptual-Motor Procedural Learning"@en .


###  https://w3id.org/MemOnto#Perceptual-Verbal_Procedural_Learning
:Perceptual-Verbal_Procedural_Learning rdf:type owl:Class ;
                                       rdfs:subClassOf :Learning ,
                                                       [ rdf:type owl:Restriction ;
                                                         owl:onProperty :isPartOf ;
                                                         owl:someValuesFrom :Procedural_Memory
                                                       ] ;
                                       rdfs:label "Perceptual-Verbal Procedural Learning"@en ;
                                      #  "Mémoire Procédurale Perceptive-Verbale"@fr ,
                                       skos:prefLabel "Perceptual-Verbal Procedural Learning"@en .


###  https://w3id.org/MemOnto#Perceptual_Memory
:Perceptual_Memory rdf:type owl:Class ;
                   rdfs:subClassOf :Cognitive_Memory_System ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :isDefinedBy ;
                                     owl:someValuesFrom :MNESIS_Model
                                   ] ,
                                   [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                            owl:onProperty :fromConcept ;
                                                            owl:someValuesFrom :PRS_Memory
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :fromModel ;
                                                            owl:someValuesFrom :SPI_Model
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasChangeType ;
                                                            owl:someValuesFrom :conceptualModification
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasChangeType ;
                                                            owl:someValuesFrom :nameModification
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :toModel ;
                                                            owl:someValuesFrom :MNESIS_Model
                                                          ]
                                                        ) ;
                                      rdf:type owl:Class
                                    ] ;
                               #  :isEvolved [ :fromConcept :PRS_Memory ;
                  #               :fromModel :SPI_Model ;
                  #               :hasChangeType :conceptualModification ,
                  #                              :nameModification ;
                  #               :toModel :MNESIS_Model
                  #             ] ;
                   terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                   rdfs:comment "\"Subtends perceptual priming effect.\" (Eustache, F., Desgranges, B. (2008)" ;
                  #  rdfs:label "Mémoire Perceptuelle"@fr ,
                   rdfs:label "Perceptual Memory"@en ;
                   skos:definition "Non-declarative memory system that stores information of the 'know how' type, directly expressed in action, difficult to verbalize, not accessible to consciousness (E. Tulving therefore describes this memory as anoetic), difficult to modify and acquired progressively." ;
                   skos:prefLabel "Perceptual Memory"@en .


###  https://w3id.org/MemOnto#Phonological_Loop
:Phonological_Loop rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty :isIntegratedIn ;
                                     owl:someValuesFrom :MNESIS_Model
                                   ] .


###  https://w3id.org/MemOnto#Procedural_Memory
:Procedural_Memory rdf:type owl:Class ;
                   terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                   rdfs:comment "\"Allows skills to be acquired through training.\" (Eustache, F., Desgranges, B. (2008))" ;
                  #  rdfs:label "Mémoire Procédurale"@fr ,
                   rdfs:label "Procedural Memory"@en ;
                  #  skos:prefLabel "Procedural Memory"@en ;
                  rdfs:subClassOf [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                            owl:onProperty :fromConcept ;
                                                            owl:someValuesFrom :Procedural_Memory
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :fromModel ;
                                                            owl:someValuesFrom :SPI_Model
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :hasChangeType ;
                                                            owl:someValuesFrom :conceptualModification
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty :toModel ;
                                                            owl:someValuesFrom :MNESIS_Model
                                                          ]
                                                        ) ;
                                    rdf:type owl:Class
                                  ] .
                  #  :isEvolved [ :fromConcept :Procedural_Memory ;
                  #               :fromModel :SPI_Model ;
                  #               :hasChangeType :conceptualModification ;
                  #               :toModel :MNESIS_Model
                  #             ] .


###  https://w3id.org/MemOnto#Semantic_Memory
:Semantic_Memory rdf:type owl:Class ;
                 terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                 rdfs:comment "\"Memory of general facts of the world.\" (Eustache, F., Desgranges, B. (2008))" .


###  https://w3id.org/MemOnto#Semanticization
:Semanticization rdf:type owl:Class ;
                 rdfs:subClassOf :Memory_Process ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :isAssociatedWith ;
                                   owl:someValuesFrom :Episodic_Memory
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :isAssociatedWith ;
                                   owl:someValuesFrom :Semantic_Memory
                                 ] ;
                 terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                 rdfs:comment "\"Going from episodic memory to semantic memory and indicates that memories tend to become semanticized over time, though not all memories necessarily become semanticized, and true episodic memories do exist, even for the far-distant past.\" (Eustache, F., Desgranges, B. (2008))" ;
                 rdfs:label "Semanticization"@en ;
                 skos:definition "\"Decontextualizing process of episodic memories with the passage of time.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                 skos:prefLabel "Semanticization"@en .


###  https://w3id.org/MemOnto#Visuo-Spatial_Sketchpad
:Visuo-Spatial_Sketchpad rdf:type owl:Class ;
                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                           owl:onProperty :isIntegratedIn ;
                                           owl:someValuesFrom :MNESIS_Model
                                         ] ;
                         terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                         rdfs:comment "\"Involved in maintaining spatial and visual information.\" (Eustache, F., Desgranges, B. (2008))" .


###  https://w3id.org/MemOnto#Working_Memory
:Working_Memory rdf:type owl:Class .


