@prefix terms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/MemOnto#> .

<https://w3id.org/SPI_Model> rdf:type owl:Ontology ;
                              owl:versionIRI <https://w3id.org/SPI_Model> ;
                              <http://purl.org/dc/elements/1.1/license> "https://creativecommons.org/licenses/by/3.0/"^^rdfs:Literal ;
                              terms:title "SPI_Model" .

