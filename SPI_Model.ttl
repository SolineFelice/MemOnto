###  http://purl.org/dc/terms/creator
terms:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
terms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  https://w3id.org/MemOnto#isCreatedBy
:isCreatedBy rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################


###  https://w3id.org/MemOnto#asAwarenessExpressionForm
:asAwarenessExpressionForm rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#characterizes
:characterizes rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#defines
:defines rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#fromConcept
:fromConcept rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#fromModel
:fromModel rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#hasAwarenessExpressionFormOfMemory
:hasAwarenessExpressionFormOfMemory rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#hasChangeType
:hasChangeType rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#holdsTrue
:holdsTrue rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#isComingFrom
:isComingFrom rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#isDefinedBy
:isDefinedBy rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#isEvolved
:isEvolved rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#isIntegratedIn
:isIntegratedIn rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#isPartOf
:isPartOf rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#isProcessOf
:isProcessOf rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#linkedToProcess
:linkedToProcess rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#memorySystem
:memorySystem rdf:type owl:ObjectProperty .


###  https://w3id.org/MemOnto#toModel
:toModel rdf:type owl:ObjectProperty .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/1999/02/22-rdf-syntax-ns#Statement
rdf:Statement rdf:type owl:Class .


###  https://w3id.org/MemOnto#Author
:Author rdf:type owl:Class ;
                 rdfs:label "Author"@en .


# ###  https://w3id.org/MemOnto#Autobiographical_Memory
# :Autobiographical_Memory rdf:type owl:Class ;
#                          rdfs:subClassOf :Cognitive_Memory_System ;
#                          skos:definition "Memory of events whose reference is the subject him or herself." ;
#                          rdfs:label "Autobiographical Memory"@en ;
#                          skos:prefLabel "Autobiographical Memory"@en ;
#                          terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
#                          :isLinguisticTermOf "Episodic_Memory" .


###  https://w3id.org/MemOnto#Awareness_Expression_Form_of_Memory
:Awareness_Expression_Form_of_Memory rdf:type owl:Class ;
                                     rdfs:label "Awareness Expression Form of Memory"@en ;
                                     skos:prefLabel "Awareness Expression Form of Memory"@en ;
                                     skos:altLabel "Forms of Expression of Memory"@en ;
                                     terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                                     rdfs:subClassOf :Concept ,
                                                     [ rdf:type owl:Restriction ;
                                                       owl:onProperty :characterizes ;
                                                       owl:someValuesFrom :Retrieval
                                                     ] .
                                    #  owl:disjointUnionOf ( :Explicit_Memory
                                    #                        :Implicit_Memory
                                    #                      ) .


###  https://w3id.org/MemOnto#Cognitive_Memory_System
:Cognitive_Memory_System rdf:type owl:Class .
                                        #  [ rdf:type owl:Restriction ;
                                        #    owl:onProperty :isDefinedBy ;
                                        #    owl:someValuesFrom :SPI_Model
                                        #  ] .


###  https://w3id.org/MemOnto#Concept
:Concept rdf:type owl:Class ;
         rdfs:label "Concept"@en .


###  https://w3id.org/MemOnto#Declarative_Memory
:Declarative_Memory rdf:type owl:Class ;
                    rdfs:label "Declarative Memory"@en ;
                    skos:prefLabel "Declarative Memory"@en ;
                    terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                    rdfs:subClassOf :Cognitive_Memory_System ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :isPartOf ;
                                      owl:someValuesFrom :Long-Term_Memory
                                    ] ;
                    skos:definition "\"Long-term memory system that stores \"know that\" information that can be verbalized, conscientiously accessed, and easily modified.\", Cognitive psychology of human memory (CogMemo thesaurus)" .


###  https://w3id.org/MemOnto#Encoding
:Encoding rdf:type owl:Class ;
          rdfs:subClassOf :Memory_Process ;
          owl:disjointWith :Storage ,
                           :Retrieval ;
          rdfs:label "Encoding"@en ;
          skos:prefLabel "Encoding"@en ;
          terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
          skos:definition "The process by which the format of information is transformed into another format compatible with memory storage." .


###  https://w3id.org/MemOnto#Episodic_Memory
:Episodic_Memory rdf:type owl:Class ;
                 skos:definition "\"Memory of personal experiences (episodes) located in time and space.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                 terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                 rdfs:label "Episodic Memory"@en ;
                 skos:prefLabel "Episodic Memory"@en ;
                 skos:altLabel "Event Memory"@en ;
                 skos:altLabel "Personal Memory"@en ;
                 skos:altLabel "Autobiographical Memory"@en ;
                 rdfs:subClassOf :Cognitive_Memory_System ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasAwarenessExpressionFormOfMemory ;
                                   owl:someValuesFrom :Explicit_Memory
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :isDefinedBy ;
                                   owl:someValuesFrom :SPI_Model
                                 ] .


###  https://w3id.org/MemOnto#Event_Memory
:Event_Memory rdf:type owl:Class ;
              terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
              rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/MemOnto#Explicit_Memory
:Explicit_Memory rdf:type owl:Class ;
                 owl:disjointWith :Implicit_Memory ;
                 terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                 rdfs:subClassOf :Awareness_Expression_Form_of_Memory ;
                #  rdfs:label "Mémoire Explicite"@fr ;
                 rdfs:label "Explicit Memory"@en ;
                 skos:prefLabel "Explicit Memory"@en ;
                 rdfs:comment "\"Explicit memory, on the other hand, refers to the expression of what the person is consciously aware of as a personal experience.\" (Tulving, E. (1995))" ;
                 skos:definition "Voluntary or involuntary conscious retrieval of a previous episode located in time and space." .


###  https://w3id.org/MemOnto#Implicit_Memory
:Implicit_Memory rdf:type owl:Class ;
                 owl:disjointWith :Explicit_Memory ;
                 rdfs:subClassOf :Awareness_Expression_Form_of_Memory ;
                 terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                #  rdfs:label "Mémoire Implicite"@fr ;
                 rdfs:label "Implicit Memory"@en ;
                 skos:prefLabel "Implicit Memory"@en ;
                 rdfs:comment "\"Implicit memory is a form of expression of memory (for Tulving and what we call \"Awareness Expression Form of Memory) designates the expression of stored information without awareness of its acquisition coordinates in space and time, that is, expression of what the individual has learned without necessarily remembering how, when, or where the learning occurred.\" (Tulving, E. (1995))" ;
                 skos:definition "A memory is defined implicit when the learned information is retrieved and used without awareness of remembering it and with no reference to the learning phase." .


###  https://w3id.org/MemOnto#Long-Term_Memory
:Long-Term_Memory rdf:type owl:Class ;
                  rdfs:subClassOf :Cognitive_Memory_System ;
                  terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                  # rdfs:label "Mémoire à Long-Terme"@fr ;
                  rdfs:label "Long-Term Memory"@en ;
                  skos:prefLabel "Long-Term Memory"@en ;
                  skos:definition "A storage system with theoretically unlimited capacity in which information is permanently held." .


###  https://w3id.org/MemOnto#Memory_Model
:Memory_Model rdf:type owl:Class ;
                 rdfs:label "Memory Model"@en .


###  https://w3id.org/MemOnto#Memory_Process
:Memory_Process rdf:type owl:Class ;
                 rdfs:label "Memory Process"@en .


###  https://w3id.org/MemOnto#PRS_Memory
:PRS_Memory rdf:type owl:Class ;
            rdfs:label "PRS Memory"@en ;
            skos:prefLabel "PRS Memory"@en ; 
            skos:altLabel "Priming_Memory"@en ;
            skos:altLabel "Perceptual Representation Systems Memory"@en ;
            rdfs:subClassOf :Cognitive_Memory_System ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :hasAwarenessExpressionFormOfMemory ;
                              owl:someValuesFrom :Implicit_Memory
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :isDefinedBy ;
                              owl:someValuesFrom :SPI_Model
                            ] ;
            terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
            rdfs:comment "\\\"In general, the PRS information tells the brain about the kinds of objects that exist in the world.\\\" (Tulving, E. (1995))" ;
            # rdfs:label "Mémoire PRS"@fr ;
            skos:definition "Memory system theorized by Tulving and Schacter (1990), which is thought to account for object or word perceptual priming effects. According to the authors, this system is involved in perceptual identification of objects and words, but without reference to their meaning." .


###  https://w3id.org/MemOnto#Primary_Memory
:Primary_Memory rdf:type owl:Class ;
                rdfs:subClassOf :Cognitive_Memory_System ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasAwarenessExpressionFormOfMemory ;
                                  owl:someValuesFrom :Explicit_Memory
                                ] ;
                terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                rdfs:comment "For Tulving, this term (Primary Memory) has the same meaning as Short-Term Memory, but he also uses it interchangeably with Working Memory." ,
                             "\\\"Primary memory, also referred to as short-term memory or working memory, registers and retains incoming information in a highly accessible form for a short period of time after the input.\\\" (Tulving, E. (1995))" ;
                # rdfs:label "Mémoire Primaire"@fr ;
                rdfs:label "Primary Memory"@en ;
                skos:prefLabel "Primary Memory"@en ;
                skos:altLabel "Working_Memory"@en ;
                skos:definition "A limited-capacity storage system in which information is held for a short duration (a few seconds) and is subject to rapid degradation." .


###  https://w3id.org/MemOnto#Procedural_Memory
:Procedural_Memory rdf:type owl:Class ;
                   skos:definition "\"Non-declarative memory system that stores information of the \"know how\" type, directly expressed in action, difficult to verbalize, not accessible to consciousness (E. Tulving therefore describes this memory as anoetic), difficult to modify and acquired progressively.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                   rdfs:label "Procedural Memory"@en ;
                   skos:prefLabel "Procedural Memory"@en ; 
                   skos:altLabel "Nondeclarative Memory"@en ;
                   terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                   rdfs:subClassOf :Cognitive_Memory_System ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasAwarenessExpressionFormOfMemory ;
                                     owl:someValuesFrom :Implicit_Memory
                                   ] .


###  https://w3id.org/MemOnto#Retrieval
:Retrieval rdf:type owl:Class ;
           owl:disjointWith :Encoding ,
                            :Storage ;
           skos:definition "\"The processes by which a person recovers stored information from memory.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
           rdfs:label "Retrieval"@en ;
           skos:prefLabel "Retrieval"@en ; 
           terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
           rdfs:subClassOf :Memory_Process .


###  https://w3id.org/MemOnto#SPI_Model
:SPI_Model rdf:type owl:Class ;
           rdfs:label "SPI Model"@en ;
           skos:prefLabel "SPI Model"@en ; 
           rdfs:subClassOf :Memory_Model ,
                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                    owl:onProperty :asAwarenessExpressionForm ;
                                                    owl:someValuesFrom :Explicit_Memory
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :linkedToProcess ;
                                                    owl:someValuesFrom :Retrieval
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :memorySystem ;
                                                    owl:someValuesFrom :Episodic_Memory
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                    owl:onProperty :asAwarenessExpressionForm ;
                                                    owl:someValuesFrom :Explicit_Memory
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :linkedToProcess ;
                                                    owl:someValuesFrom :Retrieval
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :memorySystem ;
                                                    owl:someValuesFrom :Primary_Memory
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                    owl:onProperty :asAwarenessExpressionForm ;
                                                    owl:someValuesFrom :Implicit_Memory
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :linkedToProcess ;
                                                    owl:someValuesFrom :Retrieval
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :memorySystem ;
                                                    owl:someValuesFrom :PRS_Memory
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                    owl:onProperty :asAwarenessExpressionForm ;
                                                    owl:someValuesFrom :Implicit_Memory
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :linkedToProcess ;
                                                    owl:someValuesFrom :Retrieval
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :memorySystem ;
                                                    owl:someValuesFrom :Procedural_Memory
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                    owl:onProperty :asAwarenessExpressionForm ;
                                                    owl:someValuesFrom :Implicit_Memory
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :linkedToProcess ;
                                                    owl:someValuesFrom :Retrieval
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :memorySystem ;
                                                    owl:someValuesFrom :Semantic_Memory
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ,
                           [ rdf:type owl:Restriction ;
                            owl:onProperty :defines ;
                            owl:someValuesFrom :PRS_Memory
                           ] ;
           skos:altLabel "Serial Parallel Independent Model"@en ;
           terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
           terms:created "1995-01-01T01:01:01"^^xsd:dateTime .


###  https://w3id.org/MemOnto#Semantic_Memory
:Semantic_Memory rdf:type owl:Class ;
                 rdfs:label "Semantic Memory"@en ;
                 skos:prefLabel "Semantic Memory"@en ; 
                 skos:altLabel "Factual Memory"@en ;
                 skos:altLabel "Generic Memory"@en ;
                 skos:altLabel "Knowledge Memory"@en ;
                 terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                 skos:definition "\"Long-term memory of world knowledge (words, concepts, facts...) independent of the spatio-temporal context of acquisition.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                 rdfs:subClassOf :Cognitive_Memory_System ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasAwarenessExpressionFormOfMemory ;
                                   owl:someValuesFrom :Implicit_Memory
                                 ] ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty :isPartOf ;
                                   owl:someValuesFrom :Declarative_Memory
                                 ] .


###  https://w3id.org/MemOnto#Short-Term_Memory
:Short-Term_Memory rdf:type owl:Class ;
                   rdfs:label "Short-Term Memory"@en ;
                   skos:prefLabel "Short-Term Memory"@en ; 
                   rdfs:subClassOf :Cognitive_Memory_System ;
                   terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                   skos:definition "A limited-capacity storage system in which information is held for a short duration (a few seconds) and is subject to rapid degradation." .


###  https://w3id.org/MemOnto#Storage
:Storage rdf:type owl:Class ;
         owl:disjointWith :Encoding ,
                          :Retrieval ;
         rdfs:label "Storage"@en ;
         skos:prefLabel "Storage"@en ; 
         rdfs:subClassOf :Memory_Process ;
         terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
         skos:definition "Process for the retention of information in memory." .


###  https://w3id.org/SPI_Model#Episodic_Memory
:Episodic_Memory rdf:type owl:Class ;
                 rdfs:label "Episodic Memory"@en ;
                 skos:prefLabel "Episodic Memory"@en ; 
                 terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                 skos:definition "\"Memory of personal experiences (episodes) located in time and space.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                 rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/SPI_Model#Long-Term_Memory
:Long-Term_Memory rdf:type owl:Class ;
                  skos:definition "\"A storage system with theoretically unlimited capacity in which information is permanently held.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                  rdfs:label "Long-Term Memory"@en ;
                  skos:prefLabel "Long-Term Memory"@en ; 
                  terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                  rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/SPI_Model#PRS_Memory
:PRS_Memory rdf:type owl:Class ;
            rdfs:label "PRS Memory"@en ;
            skos:prefLabel "PRS Memory"@en ; 
            skos:altLabel "Perceptual Representation Systems"@en ; 
            terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
            rdfs:comment "In general, the PRS information tells the brain about the kinds of objects that exist in the world." ;
            rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/SPI_Model#Primary_Memory
:Primary_Memory rdf:type owl:Class ;
                rdfs:label "Primary Memory"@en ;
                skos:prefLabel "Primary Memory"@en ; 
                rdfs:comment "Primary memory, also referred to as short-term memory or working memory, registers and retains in- coming information in a highly accessible form for a short period of time after the input." ;
                terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/SPI_Model#Procedural_Memory
:Procedural_Memory rdf:type owl:Class ;
                   rdfs:label "Procedural Memory"@en ;
                   skos:prefLabel "Procedural Memory"@en ; 
                   skos:definition "\"Non-declarative memory system that stores information of the \"know how\" type, directly expressed in action, difficult to verbalize, not accessible to consciousness (E. Tulving therefore describes this memory as anoetic), difficult to modify and acquired progressively.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                   terms:bibliographicCitation "Tulving, E. (1995). Organization of memory: Quo vadis? In M. S. Gazzaniga (Ed.), The Cognitive Neurosciences (p. 753-847). MIT Press." ;
                   rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/SPI_Model#Semantic_Memory
:Semantic_Memory rdf:type owl:Class ;
                 rdfs:label "Semantic Memory"@en ;
                 skos:prefLabel "Semantic Memory"@en ; 
                 skos:definition "\"Long-term memory of world knowledge (words, concepts, facts...) independent of the spatio-temporal context of acquisition.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                 rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/SPI_Model#Working_Memory
:Working_Memory rdf:type owl:Class ;
                rdfs:subClassOf :Cognitive_Memory_System .
                

#################################################################
#    Individuals
#################################################################

###  https://w3id.org/MemOnto#Tulving
:Tulving rdf:type owl:NamedIndividual ,
                  :Author ;
        #  :considers [ rdf:type rdf:Statement
        #             ] ,
        #             [ rdf:type rdf:Statement
        #             ] ,
        #             [ rdf:type rdf:Statement
