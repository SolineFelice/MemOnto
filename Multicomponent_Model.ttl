#################################################################
#    Classes
#################################################################

###  https://w3id.org/MemOnto#Author
:Author rdf:type owl:Class ;
                 rdfs:label "Author"@en .


###  https://w3id.org/MemOnto#Central_Executive
:Central_Executive rdf:type owl:Class ;
                   rdfs:label "Central Executive"@en ;
                   skos:prefLabel "Central Executive"@en ; 
                   rdfs:subClassOf :Cognitive_Memory_System ,
                   [ rdf:type owl:Restriction ;
                   owl:onProperty :isPartOf ;
                   owl:someValuesFrom :Working_Memory
                   ] ;
                   terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                   rdfs:comment "\"Supervises and coordinates the slave systems (includes executive functions).\" (Eustache, F., Desgranges, B. (2008))" ;
                  #  rdfs:label "Administrateur Central"@fr ;
                   skos:definition "Component of working memory that is responsible for attentional focus, storage, and decision making." .


###  https://w3id.org/MemOnto#Cognitive_Memory_System
:Cognitive_Memory_System rdf:type owl:Class ;
                 rdfs:label "Cognitive Memory System"@en .


###  https://w3id.org/MemOnto#Episodic_Buffer
:Episodic_Buffer rdf:type owl:Class ;
                 rdfs:label "Episodic Buffer"@en ;
                 skos:prefLabel "Episodic Buffer"@en ; 
                 rdfs:subClassOf :Cognitive_Memory_System ,
                 [ rdf:type owl:Restriction ;
                  owl:onProperty :isPartOf ;
                  owl:someValuesFrom :Working_Memory
                 ] ;
                #  rdfs:label "Tampon Épisodique"@fr ;
                 skos:definition "Component of working memory that temporarily integrates visual, spatial, and auditory information into chronologically ordered epsiodes." ;
                #  :hasLinguisticTerm :Episodic_Buffer ;
                 terms:bibliographicCitation "Baddeley A. D. (2001). Is working memory still working?. The American psychologist, 56(11), 851–864. https://doi.org/10.1037/0003-066x.56.11.851" ;
                 rdfs:comment "\"The episodic buffer is assumed to represent a storage system using a multimodal code. It is assumed to be episodic in the sense that it holds integrated episodes or scenes and to be a buffer in providing a limited capacity interface between systems using different codes.\" (Baddeley, A. D. (2001))" .


# ###  https://w3id.org/MemOnto#Linguistic_Term
# :Linguistic_Term rdf:type owl:Class ;
#                  rdfs:label "Linguistic Term"@en .


###  https://w3id.org/MemOnto#Memory_Model
:Memory_Model rdf:type owl:Class ;
                 rdfs:label "Memory Model"@en .


###  https://w3id.org/MemOnto#Multicomponent_Model
:Multicomponent_Model rdf:type owl:Class ;
                      rdfs:label "Multicomponent Model"@en ;
                      skos:prefLabel "Multicomponent Model"@en ; 
                      rdfs:subClassOf :Memory_Model ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :defines ;
                        owl:someValuesFrom :Central_Executive
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :defines ;
                        owl:someValuesFrom :Episodic_Buffer
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :defines ;
                        owl:someValuesFrom :Phonological_Loop
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :defines ;
                        owl:someValuesFrom :Phonological_Store
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :defines ;
                        owl:someValuesFrom :Articulatory_Rehearsal_System
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :defines ;
                        owl:someValuesFrom :Visuo-Spatial_Sketchpad
                      ] ;
                      terms:created "1974-01-01T01:01:01"^^xsd:dateTime ;
                      terms:bibliographicCitation "Baddeley A. D. (2001). Is working memory still working?. The American psychologist, 56(11), 851–864. https://doi.org/10.1037/0003-066x.56.11.851" ;
                      :isCreatedBy <https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/raw/main/cogatlas.owl#Baddeley> ,
                                   <https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/raw/main/cogatlas.owl#Hitch> .


###  https://w3id.org/MemOnto#Phonological_Loop
:Phonological_Loop rdf:type owl:Class ;
                   rdfs:label "Phonological Loop"@en ;
                   skos:prefLabel "Phonological Loop"@en ; 
                   skos:altLabel "Articulatory Loop"@en ;
                   rdfs:subClassOf :Cognitive_Memory_System ,
                   [ rdf:type owl:Restriction ;
                     owl:onProperty :isPartOf ;
                     owl:someValuesFrom :Working_Memory
                   ] ;
                   terms:bibliographicCitation "Eustache, F., Desgranges, B. MNESIS: Towards the Integration of Current Multisystem Models of Memory. Neuropsychol Rev 18, 53–69 (2008). https://doi.org/10.1007/s11065-008-9052-3" ;
                   rdfs:comment "\"Responsible for storing and refreshing verbal information.\" (Eustache, F., Desgranges, B. (2008))" ;
                   rdfs:comment "Baddeley and Hitch use the term Articulatory Loop to talk about the Phonological Loop before 2000" ;
                  #  rdfs:label "Boucle Phonologique"@fr ;
                   skos:definition "Component of working memory that temporarily retains auditory information." .
                  #  :hasLinguisticTerm :Phonological_Loop ;
                  #  :hasLinguisticTerm :Articulatory_Loop .


###  https://w3id.org/MemOnto#Phonological_Store
:Phonological_Store rdf:type owl:Class ;
                    rdfs:label "Phonological Store"@en ;
                    skos:prefLabel "Phonological Store"@en ; 
                    rdfs:subClassOf :Cognitive_Memory_System ,
                    [ rdf:type owl:Restriction ;
                        owl:onProperty :isPartOf ;
                        owl:someValuesFrom :Phonological_Loop
                    ] ;
                    terms:bibliographicCitation "Baddeley A. D. (2001). Is working memory still working?. The American psychologist, 56(11), 851–864. https://doi.org/10.1037/0003-066x.56.11.851" ;
                    rdfs:comment "\"Traces within the store were assumed to decay over a period of about two seconds unless refreshed by rehearsal, a process akin to subvocalization and one that is dependent on the second component, the articulatory system.\" (Baddeley, A. D., Hitch, G. (1974, 2001))" ;
                    # rdfs:label "Registre Phonologique"@fr ;
                    skos:definition "Component of the phonological loop responsible for the temporary storage of verbal information in a phonological form." .
                    # :hasLinguisticTerm :Phonological_Store .


###  https://w3id.org/MemOnto#Articulatory_Rehearsal_System
:Articulatory_Rehearsal_System rdf:type owl:Class ;
                   rdfs:label "Articulatory Rehearsal System"@en ;
                   skos:prefLabel "Articulatory Rehearsal System"@en ; 
                   rdfs:subClassOf :Cognitive_Memory_System ,
                   [ rdf:type owl:Restriction ;
                     owl:onProperty :isPartOf ;
                     owl:someValuesFrom :Phonological_Loop
                   ] ;
                   terms:bibliographicCitation "Baddeley A. D. (2001). Is working memory still working?. The American psychologist, 56(11), 851–864. https://doi.org/10.1037/0003-066x.56.11.851" ;
                   rdfs:comment "\"The articulatory rehearsal component was proposed to give an account of the word length effect, whereby immediate serial recall is a direct function of the length of the items being retained.\" (Baddeley, A. D. (2001))" ;
                  #  rdfs:label "Système de Répétition Articulatoire"@fr ;
                   skos:definition "Component of the phonological loop responsible for the temporary storage of verbal information in a phonological form." .
                  #  :hasLinguisticTerm :Articulatory_Rehearsal_System .


###  https://w3id.org/MemOnto#Rehearsal
:Rehearsal rdf:type owl:Class ;
           rdfs:label "Rehearsal"@en ;
           skos:prefLabel "Rehearsal"@en ; 
           rdfs:subClassOf :Memory_Process ;
          #  rdfs:label "Autorépétition"@fr ;
           terms:bibliographicCitation "Baddeley A. D. (2001). Is working memory still working?. The American psychologist, 56(11), 851–864. https://doi.org/10.1037/0003-066x.56.11.851" ;
           skos:definition "Mental rehearsal mechanism to retain information in short-term memory (or in working memory)." .


