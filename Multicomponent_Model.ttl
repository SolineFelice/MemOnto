<https://w3id.org/Multicomponent_Model> rdf:type owl:Ontology ;
                                         owl:versionIRI <https://w3id.org/Multicomponent_Model> ;
                                         <http://purl.org/dc/elements/1.1/license> "https://creativecommons.org/licenses/by/3.0/"^^rdfs:Literal ;
                                         terms:title "Multicomponent_Model"^^rdfs:Literal ;
                                         rdfs:comment "The Multicomponent Model is adapted from CoTOn (Cognitive Theory Ontology from Ravenschlag et al., 2023)."^^rdfs:Literal .

