###  https://w3id.org/MemOnto#Visuo-Spatial_Sketchpad
:Visuo-Spatial_Sketchpad rdf:type owl:Class ;
                         rdfs:label "Visuo-Spatial Sketchpad"@en ;
                         skos:prefLabel "Visuo-Spatial Sketchpad"@en ; 
                         rdfs:subClassOf :Cognitive_Memory_System ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :isPartOf ;
                           owl:someValuesFrom :Working_Memory
                         ] ;
                        #  rdfs:label "Calepin Visuo-Spatial"@fr ;
                         terms:bibliographicCitation "Baddeley A. D. (2001). Is working memory still working?. The American psychologist, 56(11), 851–864. https://doi.org/10.1037/0003-066x.56.11.851" ;
                         skos:definition "Component of working memory that temporarily retians visual and spatial information." .
                        #  :hasLinguisticTerm :Visuo-Spatial_Sketchpad .


###  https://w3id.org/MemOnto#Working_Memory
:Working_Memory rdf:type owl:Class ;
                 rdfs:label "Working Memory"@en ;
                 skos:prefLabel "Working Memory"@en ; 
                 #rdfs:subClassOf :Linguistic_Term ;
                 rdfs:subClassOf :Cognitive_Memory_System ,
                 [ rdf:type owl:Restriction ;
                   owl:onProperty :isDefinedBy ;
                   owl:someValuesFrom :Multicomponent_Model
                 ] ;
                 terms:bibliographicCitation "Alan Baddeley, Working Memory.Science255,556-559(1992).DOI:10.1126/science.1736359" ;
                 rdfs:comment "\"Brain system that provides temporary storage and manipulation of the information necessary for such complex cognitive tasks as language comprehension, learning, and reasoning.\" (Baddeley, A. (1992))" ;
                 skos:definition "The maintenance and retrieval of information for a short period of time." .


