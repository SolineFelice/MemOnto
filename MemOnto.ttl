#################################################################
#    Classes
#################################################################

###  http://purl.org/nemo/gufo#Event
<http://purl.org/nemo/gufo#Event> rdf:type owl:Class ;
                                  terms:bibliographicCitation "Casati, R. & Varzi, A. (2015). Events. In E.N. Zalta (Ed.), The Stanford Encyclopedia of Philosophy (Winter 2015 ed.). 19 Metaphysics Research Lab, Stanford University. https://plato.stanford.edu/archives/win2015/entries/events/" ;
                                  rdfs:comment """A gufo:ConcreteIndividual that 'occurs' or 'happens' in time. They may be instantaneous or long-running. Events are those \\\"things that happen to or are performed by\\\" (Casati and Varzi, 2015) endurants. 

Examples include actions and processes, such as a business meeting, a communicative act, a soccer match, a goal kick, the clicking of a mouse button; as well as natural occurrences such as an earthquake, the fall of the meteor that caused the extinction of the dinosaurs.

Also termed \\\"happening\\\", \\\"occurrence\\\", \\\"perdurant\\\" or \\\"occurrent\\\" in the philosophical literature.""" ;
                                  skos:prefLabel "Event"@en ;
                                  rdfs:label "Event"@en .


###  http://purl.org/nemo/gufo#RigidType
<http://purl.org/nemo/gufo#RigidType> rdf:type owl:Class ;
                                      rdfs:comment """A gufo:EndurantType which applies necessarily to its instances (see Guizzardi, 2005, chapter 4).

Examples include the types \\\"Agent\\\", \\\"Person\\\", \\\"Animal\\\", \\\"PhysicalObject\\\", \\\"Car\\\", and \\\"Tree\\\".""" ;
                                      skos:prefLabel "RigidType"@en ;
                                      rdfs:label "RigidType"@en .


###  https://w3id.org/MemOnto#Agent
:Agent rdf:type owl:Class ;
       rdfs:subClassOf <http://purl.org/nemo/gufo#RigidType> ;
       rdfs:label "Agent"@en ;
       skos:prefLabel "Agent"@en .


###  https://w3id.org/MemOnto#Author
:Author rdf:type owl:Class ;
        rdfs:subClassOf :Person ;
        terms:bibliographicCitation "A. Ravenschlag, B. Löhnert, G. Guizzardi, M. da Silva Teixeira, M. Denissen, F. Hutzler, Coton: A cognitive theory ontology for representing diverging conceptualizations of cognitive concepts, CEUR workshop proceedings 3637 (2023). Publisher Copyright: © 2023 Copyright for this paper by its authors.; Joint Ontology Workshops 2023, Episode IX: The Quebec Summer of Ontology, JOWO 2023, JOWO 2023 ; Conference date: 19-07-2023 Through 20-07-2023." ;
        rdfs:label "Author"@en ;
        skos:prefLabel "Author"@en ;
        skos:definition "The creator of a Theory." .


###  https://w3id.org/MemOnto#Cognitive_Memory_System
:Cognitive_Memory_System rdf:type owl:Class ;
                         rdfs:subClassOf :Concept ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty :isDefinedBy ;
                                           owl:someValuesFrom :Memory_Model
                                         ] ;
                         terms:bibliographicCitation "Tulving E (1985a) How many systems are there? Am Psychol 26(1):1-12" ;
                         skos:prefLabel "Cognitive Memory System"@en ;
                         rdfs:label "Cognitive Memory System"@en ;
                                #     "Systèmes de Mémoire Cognitifs"@fr ;
                         skos:definition "Memory systems are organized structures of more elementary operating components." .


###  https://w3id.org/MemOnto#Cognitive_Memory_System_State
:Cognitive_Memory_System_State rdf:type owl:Class ;
                               rdfs:subClassOf :State ;
                               skos:prefLabel "Cognitive Memory System State"@en ;
                               rdfs:label "Cognitive Memory System State"@en .

###  https://w3id.org/MemOnto#State
:State rdf:type owl:Class ;
        skos:prefLabel "State"@en ;
        rdfs:label "State"@en .


###  https://w3id.org/MemOnto#Concept
:Concept rdf:type owl:Class ;
         terms:bibliographicCitation "Y. Dudai, H. Roediger, E. Tulving, Memory concepts, 2007. doi:10.1093/acprof:oso/ 9780195310443.003.0001." ;
         rdfs:label "Concept"@en ;
         skos:prefLabel "Concept"@en ;
         skos:definition "Mental representations that encode sets of attributes that describe real or imaginary classes of items, processes or relationships." .


###  https://w3id.org/MemOnto#Consciousness
:Consciousness rdf:type owl:Class ;
               rdfs:subClassOf :Concept ;
               skos:prefLabel "Consciousness"@en ;
               rdfs:label "Consciousness"@en .


###  https://w3id.org/MemOnto#Learning
:Learning rdf:type owl:Class .


###  https://w3id.org/MemOnto#Memory_Model
:Memory_Model rdf:type owl:Class ;
              rdfs:subClassOf :Model ;
              skos:prefLabel "Memory Model"@en ;
              rdfs:label "Memory Model"@en .

###  https://w3id.org/MemOnto#Memory_Theory
:Memory_Theory rdf:type owl:Class ;
              rdfs:subClassOf :Theory ;
              skos:prefLabel "Memory Theory"@en ;
              rdfs:label "Memory Theory"@en .


###  https://w3id.org/MemOnto#Memory_Process
:Memory_Process rdf:type owl:Class ;
                rdfs:subClassOf :Process ;
                skos:prefLabel "Memory Process"@en ;
                rdfs:label "Memory Process"@en .


###  https://w3id.org/MemOnto#Model_Relation
:Model_Relation rdf:type owl:Class ;
                skos:prefLabel "Model Relation"@en ;
                rdfs:label "Model Relation"@en .


###  https://w3id.org/MemOnto#Person
:Person rdf:type owl:Class ;
        rdfs:subClassOf :Agent ;
        skos:prefLabel "Person"@en ;
        rdfs:label "Person"@en .


###  https://w3id.org/MemOnto#Process
:Process rdf:type owl:Class ;
         rdfs:subClassOf <http://purl.org/nemo/gufo#Event> ;
         terms:bibliographicCitation "R. Arp, B. Smith, A. D. Spear, Building Ontologies with Basic Formal Ontology, The MIT Press, 2015. URL: http://www.jstor.org/stable/j.ctt17kk7vw." ;
         rdfs:label "Process"@en ;
         skos:prefLabel "Process"@en ;
         skos:definition "An occurrent entity that exists in time by occurring or happening, has temporal parts, and always depends on some (at least one) material entity." .


###  https://w3id.org/MemOnto#Theory
:Theory rdf:type owl:Class ;
        terms:bibliographicCitation "Frigg, Roman and Stephan Hartmann, \"Models in Science\", The Stanford Encyclopedia of Philosophy (Winter 2025 Edition), Edward N. Zalta & Uri Nodelman (eds.)." ;
        rdfs:label "Theory"@en ;
        skos:prefLabel "Theory"@en ;
        skos:definition "A theory is taken to be a (usually deductively closed) set of sentences in a formal language." .


###  https://w3id.org/MemOnto#Model
:Model rdf:type owl:Class ;
        terms:bibliographicCitation "Frigg, Roman and Stephan Hartmann, \"Models in Science\", The Stanford Encyclopedia of Philosophy (Winter 2025 Edition), Edward N. Zalta & Uri Nodelman (eds.)." ;
        rdfs:label "Model"@en ;
        skos:prefLabel "Model"@en ;
        skos:definition "A model is a structure that makes all sentences of a theory true when its symbols are interpreted as referring to objects, relations, or functions of a structure." .


###  https://w3id.org/MemOnto#changeType
:changeType rdf:type owl:Class ;
            rdfs:label "changeType"@en ;
            skos:prefLabel "changeType"@en ;
            skos:definition """The type of change is used to determine when a concept is reused in a model other than the one that defined it.
Its subconcepts are conceptual or terminological changes.
Example of use:

                   :isEvolved [ :fromConcept :PRS_Memory ;
                                :fromModel :SPI_Model ;
                                :hasChangeType :conceptualModification ,
                                               :nameModification ;
                                :toModel :MNESIS_Model
                              ]""" .


###  https://w3id.org/MemOnto#conceptualModification
:conceptualModification rdf:type owl:Class ;
                        rdfs:subClassOf :changeType ;
                        rdfs:label "conceptualModification"@en ;
                        skos:prefLabel "conceptualModification"@en ;
                        skos:definition "The conceptual modification is used to define the reuse of an existing concept that has undergone a conceptual modification (e.g., a change in meaning, property, or components) between its initial model (indicated by the property fromModel) and its final model (indicated by the property toModel)." .


###  https://w3id.org/MemOnto#nameModification
:nameModification rdf:type owl:Class ;
                  rdfs:subClassOf :changeType ;
                  rdfs:label "nameModification"@en ;
                  skos:prefLabel "nameModification"@en ;
                  skos:definition "The terminological modification is used to define the reuse of an existing concept that has undergone a terminological change (i.e. a name change) between its initial model (indicated by the property fromModel) and its final model (indicated by the property toModel)." .


