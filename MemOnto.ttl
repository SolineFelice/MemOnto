@prefix core: <http://www.semanticweb.org/cognitive-ontologies/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix core1: <https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/raw/main/core.owl#> .
@prefix terms: <http://purl.org/dc/terms/> .
@base <https://w3id.org/MemOnto#> .

<https://w3id.org/MemOnto> rdf:type owl:Ontology ;
                           <http://purl.org/dc/terms/title> "Mem'Onto"@en ;
                           owl:versionIRI <https://w3id.org/MemOnto> ;
                           owl:imports <https://w3id.org/Autobiographical_Memory_Model> ,
                                       <https://w3id.org/Early_Decomposition_Model> ,
                                       <https://w3id.org/Embedded-Processes_Model> ,
                                       <https://w3id.org/Fuzzy_Trace_Theory> ,
                                       <https://w3id.org/Late_Decomposition_Model> ,
                                       <https://w3id.org/MNESIS_Model> ,
                                       <https://w3id.org/Modal_Model> ,
                                       <https://w3id.org/Multicomponent_Model> ,
                                       <https://w3id.org/SPI_Model> ,
                                       <https://w3id.org/TBRS_Model> ;
                           terms:license "https://creativecommons.org/licenses/by/4.0/" ;
                           <http://purl.org/dc/terms/license> "https://creativecommons.org/licenses/by/4.0/" ;
                           terms:bibliographicCitation "https://loterre.istex.fr/P66/fr/?clang=en and https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/releases/alpha-release" ;
                           <http://purl.org/dc/terms/created> "2026-03-01" ;
                           <http://purl.org/dc/terms/description> "MemOnto is a Memory Ontology developed to represent memory in its various fields of application and to bring out the similarities and divergences between theories and domains. It covers ten theories that include various concepts such as memory systems (e.g., episodic memory, long-term memory), memory processes (e.g., encoding, semanticization), types of consciousness (e.g., anoetic consciousness, autonoetic consciousness), and phenomena (e.g., false memories, phantom recollection).
MemOnto is adapted from CoTOn (Cognitive Theory Ontology from Ravenschlag et al., 2023)."^^rdfs:Literal ,
                                          "The definitions of the models from the CoTOn ontology (i.e., Modal Model, Early Decomposition Model, Embedded-Process Model, Late Decomposition Model, and the Multicomponent Model) were taken from CoTOn, while the others (i.e., Mnesis Model, Autobiographical Memory Model, Fuzzy-Trace Theory, Time-Based Ressource-Sharing Model and SPI Model) come from the CogMemo thesaurus." ;
                           <http://purl.org/vocab/vann/preferredNamespacePrefix> "memonto" ;
                           owl:priorVersion "https://w3id.org/MemOnto/1.0.0" ;
                           owl:versionInfo "2.0.0" .


