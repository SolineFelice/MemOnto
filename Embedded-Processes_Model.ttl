:Cognitive_Memory_System rdf:type owl:Class .


###  https://w3id.org/MemOnto#Embedded-Processes_Model
:Embedded-Processes_Model rdf:type owl:Class ;
                          rdfs:label "Embedded-Processes Model"@en ;
                          skos:prefLabel "Embedded-Processes Model"@en ; 
                          terms:created "1988-01-01T01:01:01"^^xsd:dateTime ;
                          terms:bibliographicCitation "Cowan, N. (1999). An Embedded-Processes Model of working memory. In A. Miyake & P. Shah (Eds.), Models of working memory: Mechanisms of active maintenance and executive control (pp. 62–101). Cambridge University Press. https://doi.org/10.1017/CBO9781139174909.006" ;
                          rdfs:subClassOf :Memory_Model ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :defines ;
                                owl:someValuesFrom :Activated_Memory
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                        owl:onProperty :isComingFrom ;
                                                        owl:someValuesFrom :Multicomponent_Model
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :isIntegratedIn ;
                                                        owl:someValuesFrom :Embedded-Processes_Model
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :memorySystem ;
                                                        owl:someValuesFrom :Central_Executive
                                                      ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ,
                              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                        owl:onProperty :isComingFrom ;
                                                        owl:someValuesFrom :Multicomponent_Model
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :isIntegratedIn ;
                                                        owl:someValuesFrom :Embedded-Processes_Model
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :memorySystem ;
                                                        owl:someValuesFrom :Working_Memory
                                                      ]
                                                    ) ;
                                rdf:type owl:Class
                              ] ;
                          # rdfs:subClassOf
                          #     [ a       owl:Restriction ;
                          #       owl:someValuesFrom :Multicomponent_Model ;
                          #       owl:onProperty :isComingFrom
                          #     ] ,
                          #     [ a       owl:Restriction ;
                          #       owl:allValuesFrom :SPI_Model ;
                          #       owl:onProperty :isIntegratedIn 
                          #     ] ,
                          #     [ a       owl:Restriction ;
                          #       owl:allValuesFrom :Central_Executive ;
                          #       owl:onProperty :memoryComponent
                          #     ] ;


                          # :holdsTrue [ :isComingFrom :Multicomponent_Model ;
                          #             :isIntegratedIn :Embedded-Processes_Model ;
                          #             :memoryComponent :Central_Executive
                          #           ] ,
                          #           [ :isComingFrom :Multicomponent_Model ;
                          #             :isIntegratedIn :Embedded-Processes_Model ;
                          #             :memorySystem :Working_Memory
                          #           ] ;
                          :isCreatedBy <https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/raw/main/cogatlas.owl#Cowan> .


###  https://w3id.org/MemOnto#Short-Term_Store
:Short-Term_Store rdf:type owl:Class ;
                  rdfs:label "Short-Term Store"@en ;
                  skos:prefLabel "Short-Term Store"@en ; 
                  rdfs:subClassOf :Cognitive_Memory_System ,
                  # [ rdf:type owl:Restriction ;
                  #   owl:onProperty :isDefinedBy ;
                  #   owl:someValuesFrom :Embedded-Processes_Model
                  # ] ,
                  [ rdf:type owl:Restriction ;
                    owl:onProperty :isPartOf ;
                    owl:someValuesFrom :Long-Term_Store
                  ] ,
                  [ rdf:type owl:Restriction ;
                    owl:onProperty :isPartOf ;
                    owl:someValuesFrom :Working_Memory
                  ] ;
                  skos:definition "\"A limited-capacity storage system in which information is held for a short duration (a few seconds) and is subject to rapid degradation.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                  terms:bibliographicCitation "Cowan, N. (1999). An Embedded-Processes Model of working memory. In A. Miyake & P. Shah (Eds.), Models of working memory: Mechanisms of active maintenance and executive control (pp. 62–101). Cambridge University Press. https://doi.org/10.1017/CBO9781139174909.006" ;
                  skos:altLabel "STS"@en .


###  https://w3id.org/MemOnto#Long-Term_Store
:Long-Term_Store rdf:type owl:Class ;
                 rdfs:label "Long-Term Store"@en ;
                 skos:prefLabel "Long-Term Store"@en ; 
                 rdfs:subClassOf :Cognitive_Memory_System ,
                 [ rdf:type owl:Restriction ;
                   owl:onProperty :isPartOf ;
                   owl:someValuesFrom :Working_Memory
                 ] ;
                #  [ rdf:type owl:Restriction ;
                #    owl:onProperty :isDefinedBy ;
                #    owl:someValuesFrom :Embedded-Processes_Model
                #  ] ;                 
                 skos:definition "\"A storage system with theoretically unlimited capacity in which information is permanently held.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                 terms:bibliographicCitation "Cowan, N. (1999). An Embedded-Processes Model of working memory. In A. Miyake & P. Shah (Eds.), Models of working memory: Mechanisms of active maintenance and executive control (pp. 62–101). Cambridge University Press. https://doi.org/10.1017/CBO9781139174909.006" ;
                 skos:altLabel "LTS"@en .


###  https://w3id.org/MemOnto#Brief_Sensory_Store
:Brief_Sensory_Store rdf:type owl:Class ;
                     rdfs:label "Brief Sensory Store"@en ;
                     skos:prefLabel "Brief Sensory Store"@en ; 
                     terms:bibliographicCitation "Cowan, N. (1999). An Embedded-Processes Model of working memory. In A. Miyake & P. Shah (Eds.), Models of working memory: Mechanisms of active maintenance and executive control (pp. 62–101). Cambridge University Press. https://doi.org/10.1017/CBO9781139174909.006" ;
                     rdfs:subClassOf :Cognitive_Memory_System ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :isPartOf ;
                       owl:someValuesFrom :Working_Memory
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :isDefinedBy ;
                       owl:someValuesFrom :Embedded-Processes_Model
                     ] .


###  https://w3id.org/MemOnto#Memory_Model
:Memory_Model rdf:type owl:Class .


