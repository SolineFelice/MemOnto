###  https://w3id.org/MemOnto#Activated_Memory
:Activated_Memory rdf:type owl:Class ;
                  rdfs:label "Activated Memory"@en ;
                  skos:prefLabel "Activated Memory"@en ; 
                  skos:exactMatch "https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/raw/main/cogatlas.owl#Activated_Memory" ;
                  rdfs:subClassOf :Cognitive_Memory_System_State ,
                  [ rdf:type owl:Restriction ;
                    owl:onProperty :isDefinedBy ;
                    owl:someValuesFrom :Embedded-Processes_Model
                  ] ,
                  [ rdf:type owl:Restriction ;
                    owl:onProperty :isStateOf ;
                    owl:someValuesFrom :Long-Term_Memory
                  ] ,
                  [ rdf:type owl:Restriction ;
                    owl:onProperty :isPartOf ;
                    owl:someValuesFrom :Working_Memory
                  ] ;
                  terms:bibliographicCitation "Cowan, N. (1999). An Embedded-Processes Model of working memory. In A. Miyake & P. Shah (Eds.), Models of working memory: Mechanisms of active maintenance and executive control (pp. 62–101). Cambridge University Press. https://doi.org/10.1017/CBO9781139174909.006" ;
                  rdfs:comment "\"Activation that is sensory and abstract and that is based on any modality and any form of representation. Activated memory is assumed to be mediated by diverse areas of association cortex, as they appear to become active not only with sensory input but also with the mental imagery and retrieval (e.g., temporal association cortex for auditory imagery).\" (Cowan, N. (1999))" ;
                  skos:definition "The maintenance of old and novel information in an accessible state that is suitable for manipulation during the performance of interfering tasks." .



###  https://w3id.org/MemOnto#Short-Term_Memory
:Short-Term_Memory rdf:type owl:Class ;
                   rdfs:label "Short-Term Memory"@en ;
                   skos:prefLabel "Short-Term Memory"@en ;
                   skos:exactMatch "https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/raw/main/cogatlas.owl#Short-Term_Memory" ;
                   terms:bibliographicCitation "Cowan, N. (1999). An Embedded-Processes Model of working memory. In A. Miyake & P. Shah (Eds.), Models of working memory: Mechanisms of active maintenance and executive control (pp. 62–101). Cambridge University Press. https://doi.org/10.1017/CBO9781139174909.006" ;
                   rdfs:subClassOf :Cognitive_Memory_System ,
                   [ rdf:type owl:Restriction ;
                     owl:onProperty :isPartOf ;
                     owl:someValuesFrom :Activated_Memory
                   ] ;
                   skos:definition "Component of activated memory that temporarily stores information." .
                   # :isPartOf <https://gitlab.com/ccns/neurocog/neurodataops/anc/classification/cognitive-ontology/-/raw/main/cogatlas.owl#Activated_Memory> .


