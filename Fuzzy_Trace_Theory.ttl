###  https://w3id.org/MemOnto#Author
:Author rdf:type owl:Class .


###  https://w3id.org/MemOnto#Cognitive_Memory_System
:Cognitive_Memory_System rdf:type owl:Class .


###  https://w3id.org/MemOnto#Dual_Process_Theory
:Dual_Process_Theory rdf:type owl:Class ;
                     rdfs:subClassOf :Memory_Theory ;
                     rdfs:label "Dual Process Theory"@en ;
                     skos:definition "\"In theories of memory, the operation of two different cognitive processes (e.g., recollection and familiarity) in recognition memory.\", APA Dictionary of Psychology" ;
                     skos:prefLabel "Dual Process Theory"@en .


###  https://w3id.org/MemOnto#False_Memory
:False_Memory rdf:type owl:Class ;
              rdfs:subClassOf :Phenomenon ;
              rdfs:label "False Memory"@en ;
              # rdfs:label "Faux Souvenirs"@fr ;
              terms:bibliographicCitation "Brainerd, C. J., & Reyna, V. F. (2019). Fuzzy-trace theory, false memory, and the law. Policy Insights from the Behavioral and Brain Sciences, 6(1), 79–86. https://doi.org/10.1177/2372732218797143" ;
              skos:definition "\"A broader term for an erroneous memory that a person holds to be true.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
              skos:prefLabel "False Memory"@en .


###  https://w3id.org/MemOnto#Familiarity
:Familiarity rdf:type owl:Class ;
             rdfs:subClassOf :Phenomenology ;
             owl:disjointWith :Recollection ;
             terms:bibliographicCitation "Brainerd, C. J., & Reyna, V. F. (2019). Fuzzy-trace theory, false memory, and the law. Policy Insights from the Behavioral and Brain Sciences, 6(1), 79–86. https://doi.org/10.1177/2372732218797143" ;
             skos:definition "\"In a recognition task, judgment that an item is old (studied) without recollection of the acquisition context, but with the feeling that the item is familiar.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
             rdfs:label "Familiarity"@en ;
             skos:prefLabel "Familiarity"@en .


###  https://w3id.org/MemOnto#Fuzzy_Trace_Theory
:Fuzzy_Trace_Theory rdf:type owl:Class ;
                    rdfs:subClassOf :Dual_Process_Theory ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :defines ;
                                      owl:someValuesFrom :Gist_Trace
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty :defines ;
                                      owl:someValuesFrom :Verbatim_Trace
                                    ] ;
                    terms:bibliographicCitation "Brainerd, C. J., & Reyna, V. F. (2019). Fuzzy-trace theory, false memory, and the law. Policy Insights from the Behavioral and Brain Sciences, 6(1), 79–86. https://doi.org/10.1177/2372732218797143" ;
                    terms:created "1995-01-01T01:01:01"^^xsd:dateTime ;
                    rdfs:label "Fuzzy Trace Theory"@en ;
                    skos:altLabel "FTT"@en ;
                    skos:prefLabel "Fuzzy Trace Theory"@en ;
                    :isCreatedBy :Brainerd ,
                                 :Reyna .


###  https://w3id.org/MemOnto#Gist_Trace
:Gist_Trace rdf:type owl:Class ;
            rdfs:subClassOf :Memory_Representation ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :experiencedAs ;
                              owl:someValuesFrom :Familiarity
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :promotes ;
                              owl:someValuesFrom :False_Memory
                            ] ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :promotes ;
                              owl:someValuesFrom :Phantom_Recollection
                            ] ;
            owl:disjointWith :Verbatim_Trace ;
            rdfs:label "Gist Trace"@en ;
            rdfs:comment "Gist traces capture salient meanings." ;
            terms:bibliographicCitation "Brainerd, C. J., & Reyna, V. F. (2019). Fuzzy-trace theory, false memory, and the law. Policy Insights from the Behavioral and Brain Sciences, 6(1), 79–86. https://doi.org/10.1177/2372732218797143" ;
            skos:altLabel "Gist Mental Representation of Information"@en ;
            skos:prefLabel "Gist Trace"@en .


###  https://w3id.org/MemOnto#Identity_Judgment
:Identity_Judgment rdf:type owl:Class ;
                   rdfs:subClassOf :Memory_Process ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty :isAssociatedWith ;
                                     owl:someValuesFrom :Verbatim_Trace
                                   ] ;
                   terms:bibliographicCitation "Rebecca K. Helm and Valerie F. Reyna, Fuzzy trace theory In: Memory in Science for Society. Edited by: Robert H. Logie, Zhisheng (Edward) Wen, Susan E. Gathercole, Nelson Cowan, and Randall W. Engle, Oxford University Press. © Oxford University Press 2023. DOI: 10.1093/​oso/​9780192849069.003.0005" ;
                   rdfs:comment "\"An identity judgement is essentially recognition of the exact thing seen or heard through retrieving the original verbatim trace and matching it to the test item\" (Helm R., Reyna V. (2023))" ;
                   rdfs:label "Identity Judgment"@en ;
                   skos:prefLabel "Identity Judgment"@en .


###  https://w3id.org/MemOnto#Memory_Model
:Memory_Model rdf:type owl:Class ;
              rdfs:label "Memory Model"@en .


###  https://w3id.org/MemOnto#Memory_Process
:Memory_Process rdf:type owl:Class ;
                rdfs:label "Memory Process"@en .


###  https://w3id.org/MemOnto#Memory_Representation
:Memory_Representation rdf:type owl:Class ;
                       rdfs:subClassOf :Mental_Representation ;
                       rdfs:label "Memory Representation"@en ;
                       skos:prefLabel "Memory Representation"@en .


###  https://w3id.org/MemOnto#Mental_Representation
:Mental_Representation rdf:type owl:Class ;
                       rdfs:subClassOf :Concept ;
                       rdfs:label "Mental Representation"@en .


###  https://w3id.org/MemOnto#Phantom_Recollection
:Phantom_Recollection rdf:type owl:Class ;
                      rdfs:subClassOf :Phenomenon ;
                      terms:bibliographicCitation "Rebecca K. Helm and Valerie F. Reyna, Fuzzy trace theory In: Memory in Science for Society. Edited by: Robert H. Logie, Zhisheng (Edward) Wen, Susan E. Gathercole, Nelson Cowan, and Randall W. Engle, Oxford University Press. © Oxford University Press 2023. DOI: 10.1093/​oso/​9780192849069.003.0005" ;
                      rdfs:comment "\"Phantom recollection can occur either simply through repeated retrieval of gist (as in repeated discussion or interrogation about a crime) or it can occur because when people process gist, they can recover realistic contextual details that make the memories appear real.\" (Helm R., Reyna V. (2023))" ;
                      skos:definition "\"Illusory but vivid recollection of the occurrence of an event.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                      rdfs:label "Phantom Recollection"@en ;
                      skos:prefLabel "Phantom Recollection"@en .


###  https://w3id.org/MemOnto#Phenomenology
:Phenomenology rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty :characterizes ;
                                 owl:someValuesFrom :Mental_Representation
                               ] ;
               rdfs:label "Phenomenology"@en ;
               skos:definition "How memories are experienced."@en ;
               skos:prefLabel "Phenomenology"@en .


###  https://w3id.org/MemOnto#Phenomenon
:Phenomenon rdf:type owl:Class ;
            rdfs:label "Phenomenon"@en ;
            skos:definition "\"[G]eneral and stable features of nature, which scientists seek to explain [...]. We tend to identify phenomena as general patterns in data - Strcutures that are observed across datasets - which, in psychology, are often called 'effects'\" (Maier et al., in press)."@en ;
            skos:prefLabel "Phenomenon"@en .


###  https://w3id.org/MemOnto#Recollection
:Recollection rdf:type owl:Class ;
              rdfs:subClassOf :Phenomenology ;
              owl:disjointWith :Familiarity ;
              skos:definition "\"In a recognition test, judgment that an item is old (has been studied) with the retrieval of specific elements of the acquisition context.\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
              rdfs:label "Recollection"@en ;
              skos:prefLabel "Recollection"@en .


###  https://w3id.org/MemOnto#Recollection_Rejection
:Recollection_Rejection rdf:type owl:Class ;
                        rdfs:subClassOf :Memory_Process ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty :isAssociatedWith ;
                                          owl:someValuesFrom :Verbatim_Trace
                                        ] ;
                        terms:bibliographicCitation "Rebecca K. Helm and Valerie F. Reyna, Fuzzy trace theory In: Memory in Science for Society. Edited by: Robert H. Logie, Zhisheng (Edward) Wen, Susan E. Gathercole, Nelson Cowan, and Randall W. Engle, Oxford University Press. © Oxford University Press 2023. DOI: 10.1093/​oso/​9780192849069.003.0005" ;
                        rdfs:comment "\"Recollection rejection involves recognizing that an item that is familiar or meaning-consistent with a viewed item is not the viewed item itself.\" (Helm R., Reyna V. (2023))" ;
                        skos:definition "\"Memory monitoring process to avoid false memories in recognition tasks and \"based on the recall of logically inconsistent information (which disqualifies the false event from having occurred)\" (Gallo et al., 2006, p. 730).\", Cognitive psychology of human memory (CogMemo thesaurus)" ;
                        rdfs:label "Recollection Rejection"@en ;
                        skos:prefLabel "Recollection Rejection"@en .


###  https://w3id.org/MemOnto#Similarity_Judgment
:Similarity_Judgment rdf:type owl:Class ;
                     rdfs:subClassOf :Memory_Process ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :isAssociatedWith ;
                                       owl:someValuesFrom :Gist_Trace
                                     ] ;
                     terms:bibliographicCitation "Rebecca K. Helm and Valerie F. Reyna, Fuzzy trace theory In: Memory in Science for Society. Edited by: Robert H. Logie, Zhisheng (Edward) Wen, Susan E. Gathercole, Nelson Cowan, and Randall W. Engle, Oxford University Press. © Oxford University Press 2023. DOI: 10.1093/​oso/​9780192849069.003.0005" ;
                     rdfs:comment "\"A similarity judgement is of meaning consistency with the thing seen or heard, based on the gist trace.\" (Helm R., Reyna V. (2023))" ;
                     rdfs:label "Similarity Judgment"@en ;
                     skos:prefLabel "Similarity Judgment"@en .


###  https://w3id.org/MemOnto#Verbatim_Trace
:Verbatim_Trace rdf:type owl:Class ;
                rdfs:subClassOf :Memory_Representation ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :experiencedAs ;
                                  owl:someValuesFrom :Recollection
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty :suppresses ;
                                  owl:someValuesFrom :False_Memory
                                ] ;
                owl:disjointWith :Gist_Trace ;
                terms:bibliographicCitation "Brainerd, C. J., & Reyna, V. F. (2019). Fuzzy-trace theory, false memory, and the law. Policy Insights from the Behavioral and Brain Sciences, 6(1), 79–86. https://doi.org/10.1177/2372732218797143" ;
                rdfs:comment "Verbatim traces capture the surface form of events." ;
                rdfs:label "Verbatim Trace"@en ;
                skos:altLabel "Verbatim Mental Representation of Information"@en ;
                skos:prefLabel "Verbatim Trace"@en .


