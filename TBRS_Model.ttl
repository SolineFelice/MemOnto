###  https://w3id.org/MemOnto#TBRS_Model
:TBRS_Model rdf:type owl:Class ;
            rdfs:label "TBRS Model"@en ;
            skos:prefLabel "TBRS Model"@en ; 
            terms:created "2021-01-01T01:01:01"^^xsd:dateTime ;
            terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
            rdfs:subClassOf :Memory_Model ,
              [ rdf:type owl:Restriction ;
                owl:onProperty :defines ;
                owl:someValuesFrom :Procedural_System_of_Representations
              ] ,
              [ rdf:type owl:Restriction ;
                owl:onProperty :defines ;
                owl:someValuesFrom :Maintenance_System
              ] ,
              [ rdf:type owl:Restriction ;
                owl:onProperty :defines ;
                owl:someValuesFrom :Attentional_Refreshing
              ] ,
              [ rdf:type owl:Restriction ;
                owl:onProperty :defines ;
                owl:someValuesFrom :Articulatory_Rehearsal
              ] ,
              [ rdf:type owl:Restriction ;
                owl:onProperty :defines ;
                owl:someValuesFrom :Episodic_Long-Term_Memory
              ] ,
              [ rdf:type owl:Restriction ;
                owl:onProperty :defines ;
                owl:someValuesFrom :Motor_Buffer
              ] ,
              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                       owl:onProperty :isComingFrom ;
                                       owl:someValuesFrom :Multicomponent_Model
                                     ]
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :isIntegratedIn ;
                                       owl:someValuesFrom :TBRS_Model
                                     ]
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :memoryComponent ;
                                       owl:someValuesFrom :Central_Executive
                                     ]
                                    ) ;
                rdf:type owl:Class
              ] ,
              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                       owl:onProperty :isComingFrom ;
                                       owl:someValuesFrom :Multicomponent_Model
                                     ]
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :isIntegratedIn ;
                                       owl:someValuesFrom :TBRS_Model
                                     ]
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :memoryComponent ;
                                       owl:someValuesFrom :Episodic_Buffer
                                     ]
                                    ) ;
                rdf:type owl:Class
              ] ,
              [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                       owl:onProperty :isComingFrom ;
                                       owl:someValuesFrom :Multicomponent_Model
                                     ]
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :isIntegratedIn ;
                                       owl:someValuesFrom :TBRS_Model
                                     ]
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :memoryComponent ;
                                       owl:someValuesFrom :Articulatory_Loop
                                     ]
                                    ) ;
                rdf:type owl:Class
              ] ;
            # :holdsTrue [ :isComingFrom :Multicomponent_Model ;
            #              :isIntegratedIn :TBRS_Model ;
            #              :memoryComponent :Central_Executive
            #            ] ,
            #            [ :isComingFrom :Multicomponent_Model ;
            #              :isIntegratedIn :TBRS_Model ;
            #              :memoryComponent :Episodic_Buffer
            #            ] ,
            #            [ :isComingFrom :Multicomponent_Model ;
            #              :isIntegratedIn :TBRS_Model ;
            #              :memoryComponent :Articulatory_Loop
            #            ] ;
            :isCreatedBy :Camos ,
                        :Barrouillet .


###  https://w3id.org/MemOnto#Procedural_System_of_Representations
:Procedural_System_of_Representations rdf:type owl:Class ;
                                      rdfs:label "Procedural System of Representations"@en ;
                                      skos:prefLabel "Procedural System of Representations"@en ; 
                                      rdfs:comment "The continuous scanning and transformation by a procedural system of representations held in the episodic buffer creates what we call the executive loop." ;
                                      rdfs:subClassOf :Cognitive_Memory_System ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :isPartOf ;
                                        owl:someValuesFrom :Episodic_Buffer
                                      ] ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :isPartOf ;
                                        owl:someValuesFrom :Executive_Loop
                                      ] ;
                                      terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                                      skos:altLabel "Working Memory Representation (mental model)"@en .


###  https://w3id.org/MemOnto#Maintenance_System
:Maintenance_System rdf:type owl:Class ;
                    terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                    rdfs:label "Maintenance System"@en ;
                    skos:prefLabel "Maintenance System"@en ;
                    rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/MemOnto#Attentional_Refreshing
:Attentional_Refreshing rdf:type owl:Class ;
                        terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                        rdfs:comment "\"Attentional refreshing maintains mental representations that are built and stored in the executive loop.\" (Barrouillet, P., & Camos, V. (2021))" ;
                        rdfs:label "Attentional Refreshing"@en ;
                        skos:prefLabel "Attentional Refreshing"@en ;
                        rdfs:subClassOf :Maintenance_System .

        
###  https://w3id.org/MemOnto#Articulatory_Rehearsal
:Articulatory_Rehearsal rdf:type owl:Class ;
                        terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                        rdfs:comment "\"Articulatory rehearsal manipulates sensorimotor patterns, the phonological loop being an output buffer holding the motor programme necessary for the verbal production of the memory items.\" (Barrouillet, P., & Camos, V. (2021))" ;
                        rdfs:label "Articulatory Rehearsal"@en ;
                        skos:prefLabel "Articulatory Rehearsal"@en ;
                        rdfs:subClassOf :Maintenance_System .


###  https://w3id.org/MemOnto#Production_System
:Production_System rdf:type owl:Class ;
                   rdfs:label "Production System"@en ;
                   skos:prefLabel "Production System"@en ; 
                   rdfs:comment "\"Following Anderson’s ACT-​R model (Anderson, 1993; Anderson & Lebiere, 1998), we assume that a production system reads the content of this representation and, through a process of pattern matching, selects the production with a condition part that matches this content and the current goal.\" (Barrouillet, P., & Camos, V. (2021))" ;
                   rdfs:subClassOf :Cognitive_Memory_System ;
                   terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                   skos:altLabel "Procedurale Long-Term Memory"@en .


###  https://w3id.org/MemOnto#Episodic_Long-Term_Memory
:Episodic_Long-Term_Memory rdf:type owl:Class ;
                           rdfs:label "Episodic Long-Term Memory"@en ;
                           skos:prefLabel "Episodic Long-Term Memory"@en ; 
                           terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                           rdfs:subClassOf :Cognitive_Memory_System ;
                           skos:altLabel "Goal Module"@en ;
                           skos:altLabel "Episodic LTM"@en .


###  https://w3id.org/MemOnto#Motor_Buffer
:Motor_Buffer rdf:type owl:Class ;
              rdfs:label "Motor Buffer"@en ;
              skos:prefLabel "Motor Buffer"@en ; 
              terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
              rdfs:subClassOf :Cognitive_Memory_System .


###  https://w3id.org/MemOnto#VisuoSpatial_Buffer
:VisuoSpatial_Buffer rdf:type owl:Class ;
                     rdfs:label "VisuoSpatial Buffer"@en ;
                     skos:prefLabel "VisuoSpatial Buffer"@en ; 
                     terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                     rdfs:subClassOf :Sensory_Buffer .


###  https://w3id.org/MemOnto#Phonological_Buffer
:Phonological_Buffer rdf:type owl:Class ;
                     rdfs:label "Phonological Buffer"@en ;
                     skos:prefLabel "Phonological Buffer"@en ; 
                     terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                     rdfs:subClassOf :Sensory_Buffer .   


###  https://w3id.org/MemOnto#Episodic_Buffer
:Episodic_Buffer rdf:type owl:Class ;
                 rdfs:label "Episodic Buffer"@en .   


###  https://w3id.org/MemOnto#Sensory_Buffer
:Sensory_Buffer rdf:type owl:Class ;
                skos:definition "Sensory Buffers are Cognitive Memory System Components which include for example Phonological Buffer, Visuospatial Buffer, Motor Buffer (but can also include auditory, musical, kinaesthetic, and haptic buffers)." ;
                terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                rdfs:label "Sensory Buffer"@en ;
                skos:prefLabel "Sensory Buffer"@en ;
                rdfs:subClassOf :Cognitive_Memory_System . 


