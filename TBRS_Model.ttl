###  https://w3id.org/MemOnto#Articulatory_Loop
:Articulatory_Loop rdf:type owl:Class ;
                   rdfs:label "Articulatory Loop"@en ;
                   skos:prefLabel "Articulatory Loop"@en ; 
                   rdfs:subClassOf :Memory_Process ,
                           [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                    owl:onProperty :fromConcept ;
                                                    owl:someValuesFrom :Phonological_Loop
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :fromModel ;
                                                    owl:someValuesFrom :Multicomponent_Model
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasChangeType ;
                                                    owl:someValuesFrom :conceptualModification
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasChangeType ;
                                                    owl:someValuesFrom :nameModification
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :toModel ;
                                                    owl:someValuesFrom :TBRS_Model
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
                   terms:bibliographicCitation "Barrouillet, P., & Camos, V. (2021). The time-based resource-sharing model of working memory. In R. H. Logie, V. Camos, & N. Cowan (Eds.), Working memory: State of the science (pp. 85–115). Oxford University Press. https://doi.org/10.1093/oso/9780198842286.003.0004" ;
                   rdfs:comment "\"We prefer to now conceive this loop dedicated for the maintenance of verbal information as an articulatory loop in which the articulatory mechanism is coupled with a buffer holding motor programmes for speech production instead of phonological representations.\" (Barrouillet, P., & Camos, V. (2021)))" .


