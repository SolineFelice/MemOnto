                                                  terms:title "Autobiographical_Memory_Model"^^rdfs:Literal ;
                                                  rdfs:comment "The Model of Autobiographical Memory assumes that memories are transitory mental constructions within a self-memory system (SMS)."^^rdfs:Literal .

